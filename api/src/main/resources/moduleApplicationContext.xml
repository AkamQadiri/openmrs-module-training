<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:context="http://www.springframework.org/schema/context"
    xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.0.xsd
                        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-3.0.xsd">

    <context:component-scan base-package="org.openmrs.module.training" />

    <!-- Service registration -->
    <bean parent="serviceContext">
        <property name="moduleService">
            <list merge="true">
                <value>org.openmrs.module.training.api.TrainingAnalyticsService</value>
                <ref bean="trainingAnalyticsService" />
            </list>
        </property>
    </bean>

    <bean parent="serviceContext">
        <property name="moduleService">
            <list merge="true">
                <value>org.openmrs.module.training.api.TrainingCourseService</value>
                <ref bean="trainingCourseService" />
            </list>
        </property>
    </bean>

    <bean parent="serviceContext">
        <property name="moduleService">
            <list merge="true">
                <value>org.openmrs.module.training.api.TrainingEnrollmentService</value>
                <ref bean="trainingEnrollmentService" />
            </list>
        </property>
    </bean>

    <bean parent="serviceContext">
        <property name="moduleService">
            <list merge="true">
                <value>org.openmrs.module.training.api.TrainingExerciseService</value>
                <ref bean="trainingExerciseService" />
            </list>
        </property>
    </bean>

    <bean parent="serviceContext">
        <property name="moduleService">
            <list merge="true">
                <value>org.openmrs.module.training.api.TrainingLessonService</value>
                <ref bean="trainingLessonService" />
            </list>
        </property>
    </bean>

    <bean parent="serviceContext">
        <property name="moduleService">
            <list merge="true">
                <value>org.openmrs.module.training.api.TrainingMediaService</value>
                <ref bean="trainingMediaService" />
            </list>
        </property>
    </bean>
</beans>