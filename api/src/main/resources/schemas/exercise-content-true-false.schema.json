{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openmrs.org/schemas/training/exercise-content-true-false.schema.json",
  "title": "True/False Exercise Content",
  "type": "object",
  "required": ["statement"],
  "properties": {
    "statement": {
      "$ref": "#/definitions/localizedText"
    }
  },
  "definitions": {
    "localizedText": {
      "type": "object",
      "patternProperties": {
        "^[a-z]{2}(-[A-Z]{2})?$": {
          "type": "string"
        }
      },
      "required": ["en"],
      "additionalProperties": false
    }
  }
}
