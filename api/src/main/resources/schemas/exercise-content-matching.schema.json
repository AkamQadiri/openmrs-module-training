{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openmrs.org/schemas/training/exercise-content-matching.schema.json",
  "title": "Matching Exercise Content",
  "type": "object",
  "required": ["instructions", "leftItems", "rightItems"],
  "properties": {
    "instructions": { "$ref": "#/definitions/localizedText" },
    "leftItems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string", "pattern": "^[1-9][0-9]*$" },
          "text": { "$ref": "#/definitions/localizedText" }
        }
      }
    },
    "rightItems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z]$" },
          "text": { "$ref": "#/definitions/localizedText" }
        }
      }
    }
  },
  "definitions": {
    "localizedText": {
      "type": "object",
      "patternProperties": {
        "^[a-z]{2}(-[A-Z]{2})?$": { "type": "string" }
      },
      "required": ["en"],
      "additionalProperties": false
    }
  }
}
